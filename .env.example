# =====================================================================
# KG-RAG Legal Assistant — environment configuration
# Copy to `.env` and fill in the keys for the providers you want to use.
# ANY layer left blank automatically falls back to a local implementation,
# so the system runs end-to-end even with this file empty.
# =====================================================================

# ---- LLM (Anthropic Claude) ----
ANTHROPIC_API_KEY=
# Reasoning model (IRAC) and fast classification model
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ---- Dense embeddings (OpenAI) ----
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-large

# ---- Knowledge graph (Neo4j AuraDB) ----
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ---- Vector store (Qdrant) ----
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_chunks

# ---- Reranker (Cohere) ----
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# ---- Local fallback embedding model (used when OPENAI_API_KEY is empty) ----
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Set true on small/free hosts (≤512 MB RAM) to skip torch/sentence-transformers
# and use a lightweight hashing embedder (fast startup, tiny footprint).
LIGHT_EMBEDDINGS=false

# ---- Pipeline tuning ----
HALLUCINATION_MAX_UNVERIFIED=0.10   # fraction of claims allowed unverified before rewrite
MAX_REWRITES=1
RETRIEVAL_TOP_K=8

# ---- Persistence (blank = SQLite at data/app.db) ----
DATABASE_URL=

# ---- Auth / security ----
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080
ADMIN_EMAIL=admin@kg-legal.ai
ADMIN_PASSWORD=admin

# ---- Subscription tiers (queries/day) ----
QUOTA_FREE=25
QUOTA_PRO=1000
QUOTA_ENTERPRISE=100000

# ---- Rate limiting & cache ----
RATE_LIMIT_PER_MIN=60
CACHE_TTL_SECONDS=900
REDIS_URL=                          # blank = in-memory cache + rate limiter

# ---- Observability (optional) ----
LANGSMITH_API_KEY=
PHOENIX_ENABLED=false
